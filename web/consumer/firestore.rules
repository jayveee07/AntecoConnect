rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'supervisor', 'general_manager'];
    }

    function isStaff() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'consumer';
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId) || isStaff();
      
      // Users can update their own profile but not change role or accountStatus
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'accountStatus', 'is_verified']));
      
      // Users can create their profile only during registration
      allow create: if isOwner(userId);
      
      // No deletion by users
      allow delete: if false;
    }

    // Master list of all ANTECO consumer accounts (CAN, owner name, address)
    match /consumers/{consumerId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // Consumer accounts
    match /consumerAccounts/{accountId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow delete: if isStaff();
    }

    // Billing statements
    match /billingStatements/{billId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow write: if isStaff();
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isStaff();
      allow delete: if false;
    }

    // Payment gateways
    match /paymentGateways/{gatewayId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Outage reports
    match /outageReports/{reportId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow delete: if isAdmin();
    }

    // Service requests
    match /serviceRequests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow delete: if isAdmin();
    }

    // Support tickets
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow delete: if isAdmin();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;  // Public read for announcements
      allow write: if isStaff();
    }

    // Planned interruptions
    match /plannedInterruptions/{interruptionId} {
      allow read: if true;  // Public read
      allow write: if isStaff();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow create: if isStaff();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    // Consumption data
    match /consumptionData/{dataId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow write: if isStaff();
    }

    // AI predictions
    match /aiPredictions/{predictionId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isStaff()
      );
      allow write: if isStaff();
    }

    // Energy saving tips
    match /energySavingTips/{tipId} {
      allow read: if true;  // Public read
      allow write: if isAdmin();
    }

    // FAQs
    match /faqs/{faqId} {
      allow read: if true;  // Public read
      allow write: if isAdmin();
    }

    // Audit logs
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;  // Server-side only
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
