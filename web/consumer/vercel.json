{
  "rewrites": [
    { "source": "/(.*\\.(png|jpg|jpeg|gif|svg|ico|webp|json|js|css|woff2?|ttf|eot))", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "unsafe-none" }
      ]
    }
  ]
}
