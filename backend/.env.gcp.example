# GCP Cloud Run + Cloud SQL environment (copy to .env for local testing)
APP_NAME=ANTECOConnect
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.anteconect.com
APP_KEY=your-app-key

# Cloud SQL (Unix socket via Cloud SQL Auth Proxy sidecar in Cloud Run)
DB_CONNECTION=pgsql
DB_HOST=/cloudsql/your-project:asia-southeast1:anteconect-db
DB_PORT=5432
DB_DATABASE=anteconect
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# Sanctum / CORS
SANCTUM_STATEFUL_DOMAINS=consumer-ten.vercel.app,admin-tau-two-97.vercel.app,localhost
SESSION_DRIVER=file
SESSION_DOMAIN=.vercel.app

# Firebase
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
FCM_SERVER_KEY=
FIREBASE_PROJECT_ID=antecoconnect
FIREBASE_API_KEY=AIzaSyAB5xg3MuXh4a8YBUHjhwplu-8_XLaafNo
FIREBASE_AUTH_DOMAIN=antecoconnect.firebaseapp.com
FIREBASE_STORAGE_BUCKET=antecoconnect.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=741998841135
FIREBASE_APP_ID=1:741998841135:web:f92f86259de5260c77a5da
FIREBASE_MEASUREMENT_ID=G-D8ZKCTS9K4

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Queue (database for MVP, Cloud Tasks later)
QUEUE_CONNECTION=database

# Cache / Session (file for MVP, Memorystore Redis later)
CACHE_DRIVER=file
SESSION_DRIVER=file

# GCP Cloud Storage
FILESYSTEM_DISK=gcs
FILESYSTEM_PUBLIC_DRIVER=gcs
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_STORAGE_BUCKET=anteconect-uploads

# Twilio / SMS (optional)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Vercel frontend URLs
VITE_APP_URL=https://consumer-ten.vercel.app
VITE_ADMIN_URL=https://admin-tau-two-97.vercel.app
